{
  "name": "litebench",
  "version": "1.0.0",
  "private": false,
  "description": "The first benchmark that actually executes tools with local AI models — real browser navigation, web search, code execution.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahostbr/LiteBench"
  },
  "homepage": "https://github.com/ahostbr/LiteBench",
  "keywords": [
    "benchmark",
    "llm",
    "local-models",
    "tool-calling",
    "agent",
    "electron",
    "lm-studio"
  ],
  "main": "./out/main/index.js",
  "author": "Ryan Devlin",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "postinstall": "node scripts/rebuild-native.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dist": "pnpm run build && electron-builder --win -c.win.signAndEditExecutable=false",
    "dist:dir": "pnpm run build && electron-builder --win --dir",
    "rebuild": "node scripts/rebuild-native.mjs"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "html2canvas": "^1.4.1",
    "htmlparser2": "^12.0.0",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "openai": "^4.86.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^34.0.2",
    "electron-builder": "^26.4.0",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty",
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.litebench.app",
    "productName": "LiteBench",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "mcp-server/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "mcp-server/**/*",
      "node_modules/.pnpm/node-pty@*/node_modules/node-pty/**",
      "node_modules/.pnpm/better-sqlite3@*/node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
